# ==============================================================
# .gitignore — Bees vs Ants Classification API
# ==============================================================

# ── Python & Environments
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/

# ── Secrets
.env
*.env
.env.*

# ── Model Artifacts & Data
# Hosting best_model.pth on external storage (Google Drive)
models/*
!models/.gitkeep
*.pt
*.pth
*.onnx
data/
hymenoptera_data/

# ── Jupyter Notebooks
.ipynb_checkpoints/

# ── Test & Coverage Artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── IDE Artifacts
.idea/
.vscode/
*.code-workspace

# ── Build & Distribution
dist/
build/
*.egg-info/

# ── OS Generated Files
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
